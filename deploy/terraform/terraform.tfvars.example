# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is listed in .gitignore — never commit real secrets.

project_id                 = "your-gcp-project-id"
region                     = "us-central1"
app_name                   = "workspace-agent"
image_tag                  = "latest"

# Set this after the first deploy — Cloud Run will assign a URL.
app_url                    = "https://workspace-agent-xxxx-uc.a.run.app"

gemini_api_key             = "AIza..."
google_client_secrets_json = <<-EOT
{
  "web": {
    "client_id": "...",
    "client_secret": "...",
    ...
  }
}
EOT

gemini_model               = "gemini-2.5-flash-native-audio-preview-09-2025"
min_instances              = 0
max_instances              = 10
cpu                        = "1"
memory                     = "512Mi"
log_level                  = "INFO"
