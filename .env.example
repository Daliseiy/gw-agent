# Copy to .env and fill in your values. Never commit .env to git.

# ── Gemini / AI ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-09-2025

# Set to true and configure project/location to use Vertex AI instead
GEMINI_USE_VERTEX_AI=false
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_SECRETS_FILE=./credentials.json
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── App config ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_HTTP_REQUESTS=true
LOG_AUDIO_CHUNKS=false
LOG_TOOL_PAYLOADS=true
CORS_ALLOW_ORIGINS=*
